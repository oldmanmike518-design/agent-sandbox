# Core
ENV=dev
LOG_LEVEL=INFO

# IMPORTANT: replace this with a random secret of at least 32 bytes in production
JWT_SECRET=generate-a-random-secret-at-least-32-characters
JWT_ISSUER=agent-sandbox
JWT_EXPIRES_DAYS=3650

# Database
# Local docker-compose default:
# DATABASE_URL=postgresql+asyncpg://sandbox:sandbox@db:5432/sandbox
DATABASE_URL=

# Redis (optional but recommended for rate limits)
# Local docker-compose default:
# REDIS_URL=redis://redis:6379/0
REDIS_URL=

# Fairness controls
# Internal credits are sandbox-only, non-monetary, and non-convertible.
STARTING_CREDITS=1000
REGISTRATION_IP_LIMIT_PER_HOUR=5
REGISTRATION_GLOBAL_LIMIT_PER_HOUR=100
REGISTRATION_LIMIT_WINDOW_SECONDS=3600
RATE_LIMIT_BUCKET_RETENTION_SECONDS=86400
# Only trust X-Forwarded-For when the immediate proxy is inside one of these CIDRs.
TRUSTED_PROXY_CIDRS=
MESSAGE_LIMIT_PER_HOUR=100
MAX_MESSAGE_CHARS=2000
MAX_DESCRIPTION_CHARS=500

# Public URL (used in docs/links in responses)
PUBLIC_BASE_URL=http://localhost:8000

# Tip jar (leave blank to omit a wallet)
OWNER_MESSAGE=Built in Cairo. Open to the universe.
WALLET_BTC=362a1J9VLksYfcDfpGmEoBotTJk3xm8fAv
WALLET_ETH=0x3f937C0dF1945619714729B23Ac049114E3b7BB3
WALLET_XRP=rw2ciyaNshpHe7bCHo4bRWq6pqqynnWKQg
WALLET_XRP_MEMO=4131367995
WALLET_XLM=GDQP2KPQGKIHYJGXNUIYOMHARUARCA7DJT5FO2FFOOKY3B2WSQHG4W37
WALLET_XLM_MEMO=21836548
WALLET_ADA=addr1vygr0pa6dk67c0qf8rjcccpxruy0j59a95dmdemyaac0ylgtqkh7w
WALLET_LINK=0xD04011aE9b7B49dd271649Fe88213985025a324A
